apiVersion: v1
kind: Secret
metadata:
  name: sealed-secrets-key
  namespace: sealed-secrets
type: kubernetes.io/tls
data:
  tls.crt: {{ lookup('community.general.onepassword', 'Sealed Secret Key', value='Network', field='public key', service_account_token=op_service_account_token) | ansible.builtin.b64encode }}
  tls.key:  {{ lookup('community.general.onepassword', 'Sealed Secret Key', value='Network', field='private key', service_account_token=op_service_account_token) | ansible.builtin.b64encode }}